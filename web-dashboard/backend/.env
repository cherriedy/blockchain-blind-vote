PORT=5000
DATABASE_URL=mongodb://127.0.0.1:27017/voting_db?replicaSet=rs0&directConnection=true
# DATABASE_URL=mongodb://mongodb:27017/voting_db?replicaSet=rs0&directConnection=true
FRONTEND_URL=http://localhost:3000

# ── Blockchain ────────────────────────────────────────────────────────────────
# RPC endpoint for Polygon Amoy (or any EVM testnet/mainnet)
RPC_URL=https://rpc-amoy.polygon.technology

# BlindBallotBox contract address — fill in after running:
#   cd blockchain && npx hardhat run scripts/deploy.js --network amoy
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Admin wallet private key (no 0x prefix) — same wallet used to deploy
ADMIN_PRIVATE_KEY=e95c3e8343245c12dcc7d571b757f07221df55d34e896636b5ea8fdfda066b65

# ── RSA Blind Signature ───────────────────────────────────────────────────────
# PEM-encoded RSA-2048 private key (with literal \n for newlines).
# Generate with:  openssl genpkey -algorithm RSA -out key.pem -pkeyopt rsa_keygen_bits:2048
# Then copy PEM content here, replacing real newlines with \n
# If not set, an EPHEMERAL key is generated on each restart (dev only).
RSA_BLIND_PRIVATE_KEY=
